{
  "id": "ralph-sr-010",
  "name": "Full pipeline integration — SGLT2i (all patches, strict criteria)",
  "phase": 2,
  "category": "integration",
  "query": "What are the effects of SGLT2 inhibitors on heart failure outcomes?",
  "expectedPapers": [
    {
      "titleFragment": "sglt2 inhibitors in heart failure",
      "mustFind": true
    },
    {
      "titleFragment": "empagliflozin",
      "mustFind": true
    },
    {
      "titleFragment": "dapagliflozin",
      "mustFind": true
    },
    {
      "titleFragment": "meta-analysis",
      "mustFind": false
    },
    {
      "titleFragment": "systematic review",
      "mustFind": false
    }
  ],
  "rankingRules": [
    {
      "rule": "RCTs (Level II) should outnumber Level V papers in top 10",
      "check": "topN_evidence_order",
      "params": { "n": 10, "higherLevel": "II", "lowerLevel": "V" }
    },
    {
      "rule": "High evidence (I-II) should outnumber low evidence (IV-V) in top 10",
      "check": "higher_level_outnumbers_lower",
      "params": { "n": 10 }
    }
  ],
  "metadataChecks": [
    {
      "check": "all_have_doi",
      "threshold": 0.85
    },
    {
      "check": "study_type_not_other",
      "threshold": 0.5
    },
    {
      "check": "year_nonzero",
      "threshold": 0.95
    },
    {
      "check": "has_abstract",
      "threshold": 0.7
    },
    {
      "check": "has_authors",
      "threshold": 0.9
    }
  ],
  "dedupChecks": [
    {
      "titleFragments": [
        "genitourinary tract infections and sglt2 inhibitors",
        "effects of empagliflozin on right ventricular"
      ],
      "maxOccurrences": 1
    }
  ]
}
