{
  "id": "ralph-sr-003",
  "name": "Study type detection — SGLT2 inhibitors (with title/abstract detector)",
  "phase": 1,
  "category": "metadata",
  "query": "What are the effects of SGLT2 inhibitors on heart failure outcomes?",
  "expectedPapers": [
    {
      "titleFragment": "sglt2 inhibitors in heart failure",
      "mustFind": true
    },
    {
      "titleFragment": "empagliflozin",
      "mustFind": true
    },
    {
      "titleFragment": "dapagliflozin",
      "mustFind": true
    },
    {
      "titleFragment": "systematic review",
      "mustFind": true
    },
    {
      "titleFragment": "meta-analysis",
      "mustFind": false
    }
  ],
  "rankingRules": [
    {
      "rule": "RCTs (Level II) should outnumber Level V papers in top 10",
      "check": "topN_evidence_order",
      "params": { "n": 10, "higherLevel": "II", "lowerLevel": "V" }
    },
    {
      "rule": "Top results should be about SGLT2i and heart failure",
      "check": "majority_on_topic",
      "params": { "n": 10, "keywords": ["sglt2", "sglt-2", "empagliflozin", "dapagliflozin", "heart failure", "sodium-glucose"], "threshold": 0.7 }
    },
    {
      "rule": "High evidence (I-II) should outnumber low evidence (IV-V) in top 10",
      "check": "higher_level_outnumbers_lower",
      "params": { "n": 10 }
    }
  ],
  "metadataChecks": [
    {
      "check": "all_have_doi",
      "threshold": 0.8
    },
    {
      "check": "study_type_not_other",
      "threshold": 0.5
    },
    {
      "check": "year_nonzero",
      "threshold": 0.95
    },
    {
      "check": "has_abstract",
      "threshold": 0.7
    }
  ],
  "dedupChecks": [
    {
      "titleFragments": [
        "differential cardiovascular benefits of sglt2 inhibitors",
        "sglt2 inhibitors and mechanisms of cardiovascular benefit"
      ],
      "maxOccurrences": 1
    }
  ]
}
