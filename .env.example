# WorkOS AuthKit — https://dashboard.workos.com
# Without these set, dev mode runs with a mock session (see src/lib/auth/config.ts).
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
# Any secure 32+ character string; used to encrypt the session cookie.
WORKOS_COOKIE_PASSWORD=""
# Must match the redirect URI configured in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/auth/callback"
# Signing secret of the WorkOS dashboard webhook endpoint that points at
# /api/sr/webhooks/workos. Verifies inbound webhook signatures (SR mirror sync).
WORKOS_WEBHOOK_SECRET=""

# Neon (serverless Postgres) — https://console.neon.tech
# Pooled connection string — used by the app at runtime (neon-http driver).
DATABASE_URL=""
# Direct (unpooled) connection string — used by drizzle-kit for migrations.
DATABASE_URL_UNPOOLED=""

# Feature flags
# Gates the whole /systematic-review route group (a medicine-only overlay). Set
# to "true" to make SR reachable; unset/anything-else keeps it off (unreachable,
# nothing in the app). Public so a future Home launcher can read it client-side.
NEXT_PUBLIC_ENABLE_SR=""

# AI screening reviewer (SR / T14)
# The LLM the AI reviewer runs, as a Vercel AI Gateway "provider/model" string.
# FOUNDER STEP: provision the provider/gateway key; without it, live screening
# fails at call time (build + tests use a deterministic mock model). Defaults to
# openai/gpt-4o-mini when unset.
SR_AI_MODEL=""
# Recorded as the ai_validations `version` (what ran). Optional; defaults to
# "gateway".
SR_AI_MODEL_VERSION=""
# Phase-1 timing for the AI (the ONE switch, founder-flippable). "silent_hold"
# (default) runs the AI during independent screening and holds its verdict
# (blinded) until reconcile; "defer_to_phase2" runs it only at reconcile. Both
# are science-safe.
SR_AI_PHASE1_MODE=""
