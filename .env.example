# WorkOS AuthKit — https://dashboard.workos.com
# Without these set, dev mode runs with a mock session (see src/lib/auth/config.ts).
WORKOS_API_KEY=""
WORKOS_CLIENT_ID=""
# Any secure 32+ character string; used to encrypt the session cookie.
WORKOS_COOKIE_PASSWORD=""
# Must match the redirect URI configured in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/auth/callback"

# Neon (serverless Postgres) — https://console.neon.tech
# Pooled connection string — used by the app at runtime (neon-http driver).
# A Neon URL (contains neon.tech) selects the neon-http driver; any other
# postgres:// URL selects node-postgres, so the app can run against a plain
# local Postgres for dev/testing without Neon creds.
DATABASE_URL=""
# Direct (unpooled) connection string — used by drizzle-kit for migrations.
DATABASE_URL_UNPOOLED=""

# Local dev without Neon: `pnpm db:local` serves an ephemeral PGlite over the
# Postgres wire protocol on :5433; point DATABASE_URL at it, then `pnpm dev`:
#   DATABASE_URL="postgres://postgres:postgres@127.0.0.1:5433/postgres"
